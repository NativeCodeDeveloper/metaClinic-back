}

### 1c. Insertar evaluacion - body vacio (debe retornar 400)
POST http://localhost:3001/evolucionClinica/insertarEvaluacion
Content-Type: application/json

{}


###############################################
# 2. SELECCIONAR EVALUACION ESPECIFICA POR ID
###############################################

### 2a. Seleccionar evaluacion especifica - caso exitoso
POST http://localhost:3001/evolucionClinica/seleccionar_evolucionEspecifica
Content-Type: application/json

{
  "id_evaluacion": 3
}

### 2b. Seleccionar evaluacion especifica - sin id_evaluacion (debe retornar 400)
POST http://localhost:3001/evolucionClinica/seleccionar_evolucionEspecifica
Content-Type: application/json

{}

### 2c. Seleccionar evaluacion especifica - id inexistente (debe retornar 200 con array vacio)
POST http://localhost:3001/evolucionClinica/seleccionar_evolucionEspecifica
Content-Type: application/json

{
  "id_evaluacion": 999999
}


###############################################
# 3. SELECCIONAR TODAS LAS EVALUACIONES
###############################################

### 3a. Seleccionar todas las evaluaciones - caso exitoso
GET http://localhost:3001/evolucionClinica/seleccionar_todas_evoluciones
Content-Type: application/json


###############################################
# 4. ELIMINAR EVALUACION (soft delete)
###############################################

### 4a. Eliminar evaluacion especifica - caso exitoso
POST http://localhost:3001/evolucionClinica/eliminar_evolucionEspecifica_controller
Content-Type: application/json

{
  "id_evaluacion": 1
}

### 4b. Eliminar evaluacion - sin id_evaluacion (debe retornar 400)
POST http://localhost:3001/evolucionClinica/eliminar_evolucionEspecifica_controller
Content-Type: application/json

{}

### 4c. Eliminar evaluacion - id inexistente (debe retornar 200 con message false)
POST http://localhost:3001/evolucionClinica/eliminar_evolucionEspecifica_controller
Content-Type: application/json

{
  "id_evaluacion": 999999
}


###############################################
# 5. ACTUALIZAR EVALUACION ESPECIFICA
###############################################

### 5a. Actualizar evaluacion - caso exitoso
POST http://localhost:3001/evolucionClinica/actualizar_evolucionEspecifica_controller
Content-Type: application/json

{
  "id_paciente": 1,
  "id_ficha_clinica": 101,
  "tipo_evaluacion": "Seguimiento",
  "version_protocolo": "v2.0",
  "estado": "Activo",
  "fecha_evaluacion": "2025-11-15 10:00:00",
  "profesional_id": 123,
  "peso_kg": 68.0,
  "talla_cm": 175,
  "cintura_cm": 82,
  "imc": 22.2,
  "pa_sistolica": 118,
  "pa_diastolica": 76,
  "actividad_fisica": "Alta",
  "motivo_consulta": "Control mensual",
  "medicamentos_actuales": "Ninguno",
  "alergias": "Penicilina",
  "tratamientos_previos_obesidad": "Dieta balanceada + ejercicio",
  "historia_familiar": "Padre con hipertension",
  "observaciones_clinicas": "Paciente muestra mejora en peso e IMC",
  "resultado_elegibilidad": "Elegible",
  "justificacion_resultado": "Mantiene criterios de elegibilidad",
  "score_total": 90,
  "fecha_creacion": "2025-10-04 14:30:00",
  "id_evaluacion": 1
}

### 5b. Actualizar evaluacion - sin id_evaluacion (debe retornar 400)
POST http://localhost:3001/evolucionClinica/actualizar_evolucionEspecifica_controller
Content-Type: application/json

{
  "id_paciente": 1,
  "id_ficha_clinica": 101,
  "tipo_evaluacion": "Seguimiento",
  "version_protocolo": "v2.0",
  "estado": "Activo"
}


###############################################
# 6. SELECCIONAR ULTIMA EVALUACION DE PACIENTE
###############################################

### 6a. Ultima evaluacion del paciente - caso exitoso
POST http://localhost:3001/evolucionClinica/seleccionar_ultimaEvaluacion_paciente
Content-Type: application/json

{
  "id_paciente": 1
}

### 6b. Ultima evaluacion - sin id_paciente (debe retornar 400)
POST http://localhost:3001/evolucionClinica/seleccionar_ultimaEvaluacion_paciente
Content-Type: application/json

{}

### 6c. Ultima evaluacion - paciente sin evaluaciones (debe retornar 200 con array vacio)
POST http://localhost:3001/evolucionClinica/seleccionar_ultimaEvaluacion_paciente
Content-Type: application/json

{
  "id_paciente": 999999
}


###############################################
# 7. SELECCIONAR TODAS LAS EVALUACIONES DE UN PACIENTE ESPECIFICO
###############################################

### 7a. Todas las evaluaciones de un paciente - caso exitoso
POST http://localhost:3001/evolucionClinica/seleccionar_todas_evaluaciones_paciente_especifico
Content-Type: application/json

{
  "id_paciente": 1
}

### 7b. Evaluaciones de paciente - sin id_paciente (debe retornar 400)
POST http://localhost:3001/evolucionClinica/seleccionar_todas_evaluaciones_paciente_especifico
Content-Type: application/json

{}

### 7c. Evaluaciones de paciente inexistente (debe retornar 200 con array vacio)
POST http://localhost:3001/evolucionClinica/seleccionar_todas_evaluaciones_paciente_especifico
Content-Type: application/json

{
  "id_paciente": 999999
}
