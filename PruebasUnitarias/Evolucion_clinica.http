###############################################
# 1. INSERTAR EVALUACION CLINICA
###############################################

### 1a. Insertar evaluacion - caso exitoso
POST http://localhost:3001/evolucionClinica/insertarEvaluacion
Content-Type: application/json

{
  "id_paciente": 1,
  "id_ficha_clinica": 101,
  "tipo_evaluacion": "Inicial",
  "version_protocolo": "v1.0",
  "estado": "Activo",
  "fecha_evaluacion": "2025-10-04 14:30:00",
  "profesional_id": 123,
  "peso_kg": 70.5,
  "talla_cm": 175,
  "cintura_cm": 85,
  "imc": 23.02,
  "pa_sistolica": 120,
  "pa_diastolica": 80,
  "actividad_fisica": "Moderada",
  "motivo_consulta": "Control de peso",
  "medicamentos_actuales": "Paracetamol",
  "alergias": "Penicilina",
  "tratamientos_previos_obesidad": "Dieta balanceada",
  "historia_familiar": "Padre con hipertension",
  "observaciones_clinicas": "Paciente presenta una dieta equilibrada y realiza ejercicio regularmente.",
  "resultado_elegibilidad": "Elegible",
  "justificacion_resultado": "Cumple con todos los criterios de elegibilidad.",
  "score_total": 85,
  "fecha_creacion": "2025-10-04 14:30:00"
}

### 1b. Insertar evaluacion - sin id_paciente (debe retornar 400)
POST http://localhost:3001/evolucionClinica/insertarEvaluacion
Content-Type: application/json

{
  "id_ficha_clinica": 101,
  "tipo_evaluacion": "Inicial",
  "version_protocolo": "v1.0",
  "estado": "Activo",
  "fecha_evaluacion": "2025-10-04 14:30:00",
  "profesional_id": 123,
  "peso_kg": 70.5,
  "talla_cm": 175,
  "cintura_cm": 85,
  "imc": 23.02,
  "pa_sistolica": 120,
  "pa_diastolica": 80,
  "actividad_fisica": "Moderada",
  "motivo_consulta": "Control de peso",
  "medicamentos_actuales": "Paracetamol",
  "alergias": "Penicilina",
  "tratamientos_previos_obesidad": "Dieta balanceada",
  "historia_familiar": "Padre con hipertension",
